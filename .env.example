# Docker Hub 不可用时，可以通过这里切换基础镜像来源。
#
# 在线替代源：
# - Elasticsearch 使用 Elastic 官方镜像仓库，不依赖 Docker Hub。
# - Python 可改成公司内网镜像仓库或国内镜像代理。
ELASTICSEARCH_BASE_IMAGE=docker.elastic.co/elasticsearch/elasticsearch:8.15.0
PYTHON_BASE_IMAGE=python:3.12-slim
IK_PLUGIN_URL=https://get.infini.cloud/elasticsearch/analysis-ik/8.15.0

# 如果 PyPI 访问慢，可启用镜像源，例如：
# PIP_INDEX_URL=https://pypi.tuna.tsinghua.edu.cn/simple
PIP_INDEX_URL=

# Admin API 密钥 — 用于数据导入和重建索引等管理操作
# 部署时务必修改为随机字符串
ADMIN_API_KEY=change-me-to-a-random-secret
