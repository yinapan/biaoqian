.env
docker-compose.override.yml
__pycache__/
*.py[cod]
.pytest_cache/

# SSL certificates (NEVER commit)
ssl/

# Data & media (large files, generated)
runtime_data/
previews/
animator/
model/
*.png
*.jpg
*.gif
*.zip
*.xlsx

# Frontend build artifacts
frontend/dist/
frontend/node_modules/
frontend/tsconfig.*.tsbuildinfo
.pnpm-store/
.npm-cache/

# E2E test runtime artifacts
tests/e2e/node_modules/
tests/e2e/test-results/
tests/e2e/playwright-report/

# Performance test reports
tests/performance/reports/

# Test/debug scripts
.playwright-mcp/
check_*.py
artifacts/
read_excel.py

# Backups
backups/

# Test fixture images — force-include despite global *.png / *.gif / dir-name ignores
# (negate the 'previews/', 'animator/', 'model/' directory rules for test paths)
!tests/
!tests/e2e/
!tests/e2e/fixtures/
!tests/e2e/fixtures/previews/
!tests/e2e/fixtures/previews/*.png
!tests/e2e/fixtures/previews/*.gif
!tests/e2e/fixtures/previews/.gitkeep
!runtime_data_test/
!runtime_data_test/model/
!runtime_data_test/model/previews/
!runtime_data_test/model/previews/*.png
!runtime_data_test/animator/
!runtime_data_test/animator/previews/
!runtime_data_test/animator/previews/*.png
!runtime_data_test/effect/
!runtime_data_test/effect/gifs/
!runtime_data_test/effect/gifs/*.gif
!runtime_data_test/ui/
!runtime_data_test/ui/pngs/
!runtime_data_test/ui/pngs/*.png

# Test runtime data files (jsonl logs, run logs) — not source artifacts
runtime_data_test/**/data.jsonl
runtime_data_test/logs/
